{
  "id": "auto-format-on-write",
  "description": "Run ruff format on any .py file after Claude writes to it",
  "event": "PostToolUse",
  "matcher": {
    "tool": "Write",
    "filePattern": "\\.py$"
  },
  "action": {
    "type": "bash",
    "command": "ruff format \"${filePath}\" && ruff check --fix --quiet \"${filePath}\"",
    "timeoutMs": 10000,
    "onFailure": "warn",
    "displayOutput": true
  }
}
